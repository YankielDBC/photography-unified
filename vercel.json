{
  "framework": "vite",
  "outputDirectory": "public",
  "buildCommand": "echo Done",
  "installCommand": "echo Done",
  "redirects": [
    { "source": "/book", "destination": "/booking", "statusCode": 302 },
    { "source": "/booking", "destination": "https://booking-three-alpha.vercel.app", "statusCode": 302 },
    { "source": "/booking/:path*", "destination": "https://booking-three-alpha.vercel.app/:path*", "statusCode": 302 }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "https://angel-photographer.vercel.app/admin" },
    { "source": "/admin/:path*", "destination": "https://angel-photographer.vercel.app/admin/:path*" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
