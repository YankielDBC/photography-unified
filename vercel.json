{
  "framework": "static",
  "buildCommand": "echo Done",
  "installCommand": "echo Done",
  "routes": [
    { "src": "/booking", "status": 200, "destination": "https://photo-booking-flax.vercel.app" },
    { "src": "/booking/(.*)", "status": 200, "destination": "https://photo-booking-flax.vercel.app/$1" },
    { "src": "/admin", "status": 200, "destination": "https://angel-photographer.vercel.app/admin" },
    { "src": "/admin/(.*)", "status": 200, "destination": "https://angel-photographer.vercel.app/admin/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "destination": "/index.html" }
  ]
}
